ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_MODE=paper

# ── Tastytrade API ──────────────────────────────────────────
# Get these from: tastytrade.com → Settings → API → OAuth Applications
# Client Secret: shown once when you create the OAuth app
# Refresh Token: Settings → API → OAuth Applications → Manage → Create Grant
TASTYTRADE_CLIENT_SECRET=your_client_secret_here
TASTYTRADE_REFRESH_TOKEN=your_refresh_token_here
TASTYTRADE_ENV=production
# Set to 'sandbox' to use api.cert.tastyworks.com for testing
# Set to 'production' to use api.tastytrade.com for live data
